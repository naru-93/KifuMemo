<!DOCTYPE html>
<html>
  <head>
    <title>棋譜MEMO</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  </head>

  <body>
    <%= render 'layouts/header' %>

    <div id="kifu-overlay" style="display:none;"></div>
    
    <div id="kifu-form" class="d-flex justify-content-center mt-4 hidden">
      <div class="card shadow" style="width: 100%; max-width: 700px;">
        <div class="card-body">
          <h5 class="card-title">棋譜の読み込み</h5>
          <form id="kifu-upload-form">
            <div class="form-group">
              <textarea id="kifu_text" name="kifu_text" class="form-control" rows="10" placeholder="ここにKIF形式の棋譜を貼り付けてください"></textarea>
            </div>
            <div class="text-end mt-3">
              <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-play"></i> 読み込む
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%= yield %>
    <%= render 'layouts/footer' %>

    <% if controller.controller_name == 'kifus' && controller.action_name == 'show' %>
      <%= javascript_pack_tag 'board', 'data-turbolinks-track': 'reload' %>
    <% end %>
  </body>
</html>