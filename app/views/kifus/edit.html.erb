<h3 class="text-center mt-4">棋譜の編集</h3>

<div class="d-flex justify-content-center mt-4">
  <div class="card shadow" style="max-width: 700px; width:100%;">
    <div class="card-body">
      <%= form_with model: @kifu, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :title, "棋譜タイトル", class: "form-label" %>
          <%= f.text_field :title, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :category_id, "戦法タグ", class: "form-label" %>
          <%= f.collection_select :category_id, @categories, :id, :name,
                { prompt: "— 選択してください —" },
                { class: "form-control", required: true } %>
        </div>

        <div class="text-center">
          <%= f.submit "更新する", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>