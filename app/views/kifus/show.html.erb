<main>
  <div class="container d-flex px-5 px-sm-0 mt-3">
    <div class="title-board">
      <div id="kifu-title" style="text-align: center; margin-bottom: 15px; font-size: 1.5rem; font-weight: bold;">
        <%= @kifu.title %>
      </div>

      <div id="shogi-container" data-kifu-id="<%= @kifu.id %>" data-comments="<%= @comments_hash.to_json %>">
        <div id="top-row">
          <div id="gote-hand" class="komadai p-2"></div>
        </div>

        <div id="middle-row">
          <div id="boad-wapper" style="background-color: #cc841d; padding: 15px; display: inline-block;">
            <div id="shogi-board"></div>
          </div>
        </div>

        <div id="bottom-row">
          <div id="sente-hand" class="komadai p-2"></div>
        </div>
      </div>

      <div id="bn-controls" class="flex text-center gap-4 mt-3">
        <button id="btn-back" class="px-4 py-2 mr-5 rounded shadow">◀︎</button>
        <span id="move-counter"></span>
        <button id="btn-next" class="px-4 py-2 ml-5 rounded shadow">▶︎</button>
      </div>
    </div>

    <div class="info-comments">
      <div id="comment-section">
        <textarea id="comment-input-area" class="form-control" rows="5" placeholder="この手へのコメント..."></textarea>
        <button id="save-comment-btn" class="btn btn-primary mt-2">コメントを保存</button>
      </div>
    <div>
  <div>  

  <div id="promotion-choice" class="promotion-ui">
    <div>
      <img id="promote-yes-img" alt="成る">
      <img id="promote-no-img" alt="成らない">
    </div>
  </div>

  <script id="jkf-data" type="application/json">
    <%= @jkf.to_json.html_safe %>
  </script>
</main>